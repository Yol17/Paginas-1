@page "/"

<header>
    <div class="logo">
        <!-- Reemplaza con el logo de tu empresa -->
        <img src="images/logo.png" alt="Logo Empresa">
    </div>
    <h1>Servicios de CIOS</h1>
</header>

<main>
    <section class="services">
        <h2>Nuestros Servicios</h2>
        <div class="grid">
            <div class="service-item">
                <h3>Servicio 1</h3>
                <p>Descripción del servicio 1.</p>
            </div>
            <div class="service-item">
                <h3>Servicio 2</h3>
                <p>Descripción del servicio 2.</p>
            </div>
            <div class="service-item">
                <h3>Servicio 3</h3>
                <p>Descripción del servicio 3.</p>
            </div>
            <!-- Agrega más servicios según sea necesario -->
        </div>
    </section>

    <section class="contact-form">
        <h2>Contáctanos</h2>
        <EditForm Model="@contactModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
                <label for="name">Nombre:</label>
                <InputText id="name" @bind-Value="contactModel.Name" />
            </div>

            <div>
                <label for="email">Correo Electrónico:</label>
                <InputText id="email" @bind-Value="contactModel.Email" />
            </div>

            <div>
                <label for="phone">Teléfono:</label>
                <InputText id="phone" @bind-Value="contactModel.Phone" />
            </div>

            <div>
                <label for="message">Mensaje:</label>
                <InputTextArea id="message" @bind-Value="contactModel.Message" />
            </div>

            <button type="submit">Enviar</button>
        </EditForm>
    </section>
</main>

<footer>
    <div class="contact-info">
        <p>Contacto:</p>
        <p>Email: contacto@empresa.com</p>
        <p>Teléfonos: (123) 456-7890</p>
        <div class="social-media">
            <a href="https://facebook.com" target="_blank"><img src="images/facebook-logo.png" alt="Facebook"></a>
            <a href="https://twitter.com" target="_blank"><img src="images/twitter-logo.png" alt="Twitter"></a>
            <a href="https://linkedin.com" target="_blank"><img src="images/linkedin-logo.png" alt="LinkedIn"></a>
        </div>
    </div>
</footer>

@code {
    private ContactModel contactModel = new ContactModel();

    private void HandleValidSubmit()
    {
        // Aquí puedes manejar el envío del formulario
    }

    public class ContactModel
    {
        public string? Name { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Message { get; set; }
    }
}

